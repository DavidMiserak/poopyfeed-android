<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/LoginFragment">

    <fragment
        android:id="@+id/LoginFragment"
        android:name="net.poopyfeed.pf.accounts.LoginFragment"
        android:label="@string/login_title"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_childrenList"
            app:destination="@id/ChildrenListFragment"
            app:popUpTo="@id/LoginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/SignupFragment" />
    </fragment>

    <fragment
        android:id="@+id/HomeFragment"
        android:name="net.poopyfeed.pf.HomeFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_loginFragment"
            app:destination="@id/LoginFragment"
            app:popUpTo="@id/HomeFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_homeFragment_to_childrenList"
            app:destination="@id/ChildrenListFragment" />

        <action
            android:id="@+id/action_homeFragment_to_pendingInvitesFragment"
            app:destination="@id/pendingInvitesFragment" />
    </fragment>

    <fragment
        android:id="@+id/pendingInvitesFragment"
        android:name="net.poopyfeed.pf.sharing.PendingInvitesFragment"
        android:label="@string/pending_invites_title"
        tools:layout="@layout/fragment_pending_invites">

        <action
            android:id="@+id/action_pendingInvitesFragment_to_childDetail"
            app:destination="@id/ChildDetailFragment"
            app:popUpTo="@id/pendingInvitesFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/ChildrenListFragment"
        android:name="net.poopyfeed.pf.children.ChildrenListFragment"
        android:label="@string/children_list_title"
        tools:layout="@layout/fragment_children_list">

        <action
            android:id="@+id/action_childrenList_to_childDetail"
            app:destination="@id/ChildDetailFragment" />

        <action
            android:id="@+id/action_childrenList_to_fabSheet"
            app:destination="@id/childrenListFabSheet" />
    </fragment>

    <dialog
        android:id="@+id/childrenListFabSheet"
        android:name="net.poopyfeed.pf.children.ChildrenListFabBottomSheetFragment"
        android:label="@string/children_list_fab_sheet_title"
        tools:layout="@layout/fragment_children_list_fab_sheet" />

    <fragment
        android:id="@+id/ChildDetailFragment"
        android:name="net.poopyfeed.pf.children.ChildDetailFragment"
        android:label="@string/children_list_title"
        tools:layout="@layout/fragment_child_detail">

        <argument
            android:name="childId"
            app:argType="integer" />

        <action
            android:id="@+id/action_childDetail_to_feedingsList"
            app:destination="@id/FeedingsListFragment" />
        <action
            android:id="@+id/action_childDetail_to_diapersList"
            app:destination="@id/DiapersListFragment" />
        <action
            android:id="@+id/action_childDetail_to_napsList"
            app:destination="@id/NapsListFragment" />

        <action
            android:id="@+id/action_childDetail_to_sharingFragment"
            app:destination="@id/sharingFragment" />

        <action
            android:id="@+id/action_childDetail_to_quickLogSheet"
            app:destination="@id/childDetailQuickLogSheet" />

        <action
            android:id="@+id/action_childDetail_to_editChild"
            app:destination="@id/EditChildFragment" />
    </fragment>

    <dialog
        android:id="@+id/childDetailQuickLogSheet"
        android:name="net.poopyfeed.pf.children.ChildDetailQuickLogBottomSheetFragment"
        android:label="@string/quick_log_sheet_title"
        tools:layout="@layout/fragment_child_detail_quick_log_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
    </dialog>

    <fragment
        android:id="@+id/sharingFragment"
        android:name="net.poopyfeed.pf.sharing.SharingFragment"
        android:label="@string/sharing_title"
        tools:layout="@layout/fragment_sharing">

        <argument
            android:name="childId"
            app:argType="integer" />

        <action
            android:id="@+id/action_sharingFragment_to_createInviteBottomSheet"
            app:destination="@id/createInviteBottomSheet" />
    </fragment>

    <fragment
        android:id="@+id/FeedingsListFragment"
        android:name="net.poopyfeed.pf.feedings.FeedingsListFragment"
        android:label="@string/feedings_list_title"
        tools:layout="@layout/fragment_feedings_list">

        <argument
            android:name="childId"
            app:argType="integer" />

        <action
            android:id="@+id/action_feedingsList_to_createFeeding"
            app:destination="@id/createFeedingBottomSheet" />
        <action
            android:id="@+id/action_feedingsList_to_editFeeding"
            app:destination="@id/editFeedingBottomSheet" />
    </fragment>

    <fragment
        android:id="@+id/DiapersListFragment"
        android:name="net.poopyfeed.pf.diapers.DiapersListFragment"
        android:label="@string/diapers_list_title"
        tools:layout="@layout/fragment_diapers_list">

        <argument
            android:name="childId"
            app:argType="integer" />

        <action
            android:id="@+id/action_diapersList_to_createDiaper"
            app:destination="@id/createDiaperBottomSheet" />
        <action
            android:id="@+id/action_diapersList_to_editDiaper"
            app:destination="@id/editDiaperBottomSheet" />
    </fragment>

    <fragment
        android:id="@+id/NapsListFragment"
        android:name="net.poopyfeed.pf.naps.NapsListFragment"
        android:label="@string/naps_list_title"
        tools:layout="@layout/fragment_naps_list">

        <argument
            android:name="childId"
            app:argType="integer" />

        <action
            android:id="@+id/action_napsList_to_createNap"
            app:destination="@id/createNapBottomSheet" />
        <action
            android:id="@+id/action_napsList_to_editNap"
            app:destination="@id/editNapBottomSheet" />
    </fragment>

    <fragment
        android:id="@+id/NotificationsFragment"
        android:name="net.poopyfeed.pf.notifications.NotificationsFragment"
        android:label="@string/notifications_title"
        tools:layout="@layout/fragment_notifications">

        <action
            android:id="@+id/action_notificationsFragment_to_childDetail"
            app:destination="@id/ChildDetailFragment" />
    </fragment>

    <dialog
        android:id="@+id/createFeedingBottomSheet"
        android:name="net.poopyfeed.pf.feedings.CreateFeedingBottomSheetFragment"
        android:label="@string/create_feeding_title"
        tools:layout="@layout/fragment_create_feeding_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
    </dialog>

    <dialog
        android:id="@+id/editFeedingBottomSheet"
        android:name="net.poopyfeed.pf.feedings.EditFeedingBottomSheetFragment"
        android:label="@string/edit_feeding_title"
        tools:layout="@layout/fragment_create_feeding_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
        <argument
            android:name="feedingId"
            app:argType="integer" />
    </dialog>

    <dialog
        android:id="@+id/createDiaperBottomSheet"
        android:name="net.poopyfeed.pf.diapers.CreateDiaperBottomSheetFragment"
        android:label="@string/create_diaper_title"
        tools:layout="@layout/fragment_create_diaper_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
    </dialog>

    <dialog
        android:id="@+id/editDiaperBottomSheet"
        android:name="net.poopyfeed.pf.diapers.EditDiaperBottomSheetFragment"
        android:label="@string/edit_diaper_title"
        tools:layout="@layout/fragment_create_diaper_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
        <argument
            android:name="diaperId"
            app:argType="integer" />
    </dialog>

    <dialog
        android:id="@+id/createNapBottomSheet"
        android:name="net.poopyfeed.pf.naps.CreateNapBottomSheetFragment"
        android:label="@string/create_nap_title"
        tools:layout="@layout/fragment_create_nap_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
    </dialog>

    <dialog
        android:id="@+id/editNapBottomSheet"
        android:name="net.poopyfeed.pf.naps.EditNapBottomSheetFragment"
        android:label="@string/edit_nap_title"
        tools:layout="@layout/fragment_edit_nap_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
        <argument
            android:name="napId"
            app:argType="integer" />
    </dialog>

    <dialog
        android:id="@+id/createChildBottomSheet"
        android:name="net.poopyfeed.pf.children.CreateChildBottomSheetFragment"
        android:label="@string/create_child_title"
        tools:layout="@layout/fragment_create_child_bottom_sheet" />

    <fragment
        android:id="@+id/EditChildFragment"
        android:name="net.poopyfeed.pf.children.EditChildFragment"
        android:label="@string/edit_child_title"
        tools:layout="@layout/fragment_edit_child_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
    </fragment>

    <dialog
        android:id="@+id/createInviteBottomSheet"
        android:name="net.poopyfeed.pf.sharing.CreateInviteBottomSheetFragment"
        android:label="@string/create_invite_title"
        tools:layout="@layout/fragment_create_invite_bottom_sheet">

        <argument
            android:name="childId"
            app:argType="integer" />
    </dialog>

    <fragment
        android:id="@+id/AccountSettingsFragment"
        android:name="net.poopyfeed.pf.accounts.AccountSettingsFragment"
        android:label="@string/account_settings_title"
        tools:layout="@layout/fragment_account_settings" />

    <fragment
        android:id="@+id/SignupFragment"
        android:name="net.poopyfeed.pf.accounts.SignupFragment"
        android:label="@string/signup_title"
        tools:layout="@layout/fragment_signup">

        <action
            android:id="@+id/action_signupFragment_to_childrenList"
            app:destination="@id/ChildrenListFragment"
            app:popUpTo="@id/LoginFragment"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>

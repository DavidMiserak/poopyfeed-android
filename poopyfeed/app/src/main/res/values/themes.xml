<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme with brand colors -->
    <style name="Base.Theme.Pf" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/dm_sans</item>
        <!-- Disable Material You dynamic colors so our brand palette is used (Android 12+) -->
        <item name="dynamicColorThemeOverlay">@null</item>

        <!-- Primary (Rose) -->
        <item name="colorPrimary">@color/rose_400</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/rose_100</item>
        <item name="colorOnPrimaryContainer">@color/rose_600</item>

        <!-- Secondary (Orange) -->
        <item name="colorSecondary">@color/orange_400</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/orange_50</item>
        <item name="colorOnSecondaryContainer">@color/amber_600</item>

        <!-- Tertiary (Amber) -->
        <item name="colorTertiary">@color/amber_400</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorTertiaryContainer">@color/amber_50</item>
        <item name="colorOnTertiaryContainer">@color/amber_600</item>

        <!-- Surface / Background -->
        <item name="colorSurface">@color/slate_50</item>
        <item name="colorOnSurface">@color/slate_900</item>
        <item name="colorSurfaceVariant">@color/slate_100</item>
        <item name="colorOnSurfaceVariant">@color/slate_600</item>
        <item name="colorOutline">@color/slate_200</item>
        <item name="android:colorBackground">@color/slate_50</item>
        <item name="colorOnBackground">@color/slate_900</item>

        <!-- Error -->
        <item name="colorError">@color/red_500</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/red_50</item>
        <item name="colorOnErrorContainer">@color/light_onErrorContainer</item>
    </style>

    <!-- Light theme -->
    <style name="Theme.Pf" parent="Base.Theme.Pf">
        <!-- Transparent system bars for edge-to-edge (API 23+) -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
    </style>

    <!-- ===================== -->
    <!-- Button Styles         -->
    <!-- ===================== -->

    <!-- Primary button (refined, minimal elevation) -->
    <style name="Widget.Pf.Button.Primary" parent="Widget.Material3.Button.UnelevatedButton">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:fontFamily">@font/dm_sans_bold</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">4dp</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
    </style>

    <!-- Secondary outlined button (refined border) -->
    <style name="Widget.Pf.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/dm_sans_medium</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
    </style>

    <!-- Quick log: primary button with visible border (OutlinedButton so stroke applies) -->
    <style name="Widget.Pf.Button.Primary.Bordered" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:fontFamily">@font/dm_sans_bold</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
    </style>

    <!-- Quick log: secondary button with thicker border -->
    <style name="Widget.Pf.Button.Secondary.Bordered" parent="Widget.Pf.Button.Secondary">
        <item name="strokeWidth">2dp</item>
    </style>

    <!-- ===================== -->
    <!-- FAB Style             -->
    <!-- ===================== -->

    <style name="Widget.Pf.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">?attr/colorPrimaryContainer</item>
        <item name="tint">?attr/colorOnPrimaryContainer</item>
        <item name="elevation">12dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Pf.FAB</item>
    </style>

    <style name="ShapeAppearance.Pf.FAB" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- ===================== -->
    <!-- Card Styles           -->
    <!-- ===================== -->

    <!-- Activity list card (subtle divider-based design) -->
    <style name="Widget.Pf.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">@dimen/corner_radius_md</item>
    </style>

    <!-- Frosted glass card (refined border, minimal elevation) -->
    <style name="Widget.Pf.CardView.Frosted" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerHigh</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">@dimen/corner_radius_lg</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- ===================== -->
    <!-- Text Styles (Fredoka) -->
    <!-- ===================== -->

    <style name="TextAppearance.Pf.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/fredoka</item>
    </style>

    <style name="TextAppearance.Pf.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/fredoka</item>
    </style>

    <style name="TextAppearance.Pf.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/fredoka</item>
    </style>

    <style name="TextAppearance.Pf.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/fredoka</item>
    </style>

    <!-- ========================== -->
    <!-- Text Styles (DM Sans body) -->
    <!-- ========================== -->

    <style name="TextAppearance.Pf.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>

    <style name="TextAppearance.Pf.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/dm_sans</item>
    </style>

    <style name="TextAppearance.Pf.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:fontFamily">@font/dm_sans_medium</item>
    </style>

</resources>

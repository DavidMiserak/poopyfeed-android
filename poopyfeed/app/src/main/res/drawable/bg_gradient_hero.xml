<?xml version="1.0" encoding="utf-8"?>
<!-- Hero banner gradient: rose-400 → rose-500 → orange-400 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="0"
        android:startColor="@color/rose_400"
        android:centerColor="@color/rose_500"
        android:endColor="@color/orange_400"
        android:type="linear" />
    <corners android:radius="@dimen/corner_radius_lg" />
</shape>

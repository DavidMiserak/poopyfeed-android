<?xml version="1.0" encoding="utf-8"?>
<!-- Primary CTA gradient: rose-400 → orange-400 → amber-400 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="315"
        android:startColor="@color/rose_400"
        android:centerColor="@color/orange_400"
        android:endColor="@color/amber_400"
        android:type="linear" />
    <corners android:radius="@dimen/corner_radius_md" />
</shape>

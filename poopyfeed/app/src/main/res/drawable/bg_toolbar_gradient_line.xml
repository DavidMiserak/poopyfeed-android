<?xml version="1.0" encoding="utf-8"?>
<!-- Thin gradient accent line: rose-400 → orange-400 → amber-300 (horizontal) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="0"
        android:startColor="@color/rose_400"
        android:centerColor="@color/orange_400"
        android:endColor="@color/amber_400"
        android:type="linear" />
    <size android:height="2dp" />
</shape>

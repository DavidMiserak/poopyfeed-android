<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    tools:context="net.poopyfeed.pf.ui.timeline.TimelineFragment">

    <!-- Day header with navigation -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_12"
        android:paddingVertical="@dimen/spacing_12">

        <!-- Previous button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_previous"
            style="?attr/borderlessButtonStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:minHeight="48dp"
            android:minWidth="48dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Day header -->
        <TextView
            android:id="@+id/text_day_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fredoka"
            android:textSize="@dimen/text_headline_medium"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/btn_previous"
            app:layout_constraintEnd_toStartOf="@id/btn_next"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="Today" />

        <!-- Next button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="?attr/borderlessButtonStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="→"
            android:textSize="20sp"
            android:minHeight="48dp"
            android:minWidth="48dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:alpha="0.12" />

    <!-- Timeline events RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_timeline"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="@dimen/spacing_6"
        android:paddingEnd="@dimen/spacing_6"
        android:paddingTop="@dimen/spacing_12"
        android:paddingBottom="@dimen/spacing_24"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_timeline_event" />

    <!-- Empty state (no events for this day) -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No events recorded"
            android:fontFamily="@font/fredoka"
            android:textSize="@dimen/text_headline_small"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="@dimen/spacing_8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No feedings, diapers, or naps logged for this day"
            android:fontFamily="@font/dm_sans"
            android:textSize="@dimen/text_body_medium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:paddingHorizontal="@dimen/spacing_12" />

    </LinearLayout>

    <!-- Error state -->
    <LinearLayout
        android:id="@+id/layout_error_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_12"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Failed to load timeline"
            android:fontFamily="@font/fredoka"
            android:textSize="@dimen/text_headline_small"
            android:textColor="?attr/colorError"
            android:layout_marginBottom="@dimen/spacing_8" />

        <TextView
            android:id="@+id/text_error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:textSize="@dimen/text_body_medium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_16"
            tools:text="Network error" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            style="@style/Widget.Pf.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retry" />

    </LinearLayout>

</LinearLayout>

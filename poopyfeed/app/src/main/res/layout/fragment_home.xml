<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    tools:context=".HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_8"
        android:paddingVertical="@dimen/spacing_12"
        android:maxWidth="@dimen/bottom_sheet_max_width">

        <!-- ======================== -->
        <!-- Decorative background blobs -->
        <!-- ======================== -->

        <View
            android:id="@+id/blob_rose"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_blob_rose"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-20dp"
            android:layout_marginEnd="-40dp" />

        <View
            android:id="@+id/blob_orange"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="@drawable/bg_blob_orange"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="-40dp"
            android:layout_marginStart="-40dp" />

        <!-- ======================== -->
        <!-- Hero welcome banner (gradient) -->
        <!-- ======================== -->

        <!-- Welcome banner (refined, minimal elevation) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_welcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_0"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorPrimaryContainer"
                android:paddingStart="@dimen/spacing_12"
                android:paddingEnd="@dimen/spacing_12"
                android:paddingTop="@dimen/spacing_16"
                android:paddingBottom="@dimen/spacing_16">

                <!-- Welcome text (white on gradient) -->
                <TextView
                    android:id="@+id/text_welcome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fredoka"
                    android:textSize="@dimen/text_headline_medium"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="👋 Welcome, Sarah" />

                <!-- Subtitle (light rose on gradient) -->
                <TextView
                    android:id="@+id/text_home_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:text="@string/home_subtitle"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="@dimen/text_body_large"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_welcome" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ======================== -->
        <!-- Pending invites card (visible when user has pending invites) -->
        <!-- ======================== -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_pending_invites"
            style="@style/Widget.Pf.CardView.Frosted"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:foreground="?attr/selectableItemBackground"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_welcome">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_12">

                <TextView
                    android:id="@+id/text_pending_invites_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/pending_invites_card_title"
                    android:textAppearance="@style/TextAppearance.Pf.TitleLarge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/icon_pending_invites_chevron"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_pending_invites_body"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:text="@string/pending_invites_card_body"
                    android:textAppearance="@style/TextAppearance.Pf.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/icon_pending_invites_chevron"
                    app:layout_constraintTop_toBottomOf="@id/text_pending_invites_title" />

                <ImageView
                    android:id="@+id/icon_pending_invites_chevron"
                    android:layout_width="@dimen/spacing_12"
                    android:layout_height="@dimen/spacing_12"
                    android:layout_marginStart="@dimen/spacing_4"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:tint="?attr/colorOnSurfaceVariant" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ======================== -->
        <!-- My Children card -->
        <!-- ======================== -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_my_children"
            style="@style/Widget.Pf.CardView.Frosted"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:layout_marginBottom="@dimen/spacing_12"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_pending_invites">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_12">

                <TextView
                    android:id="@+id/text_my_children_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/home_children_card_title"
                    android:textAppearance="@style/TextAppearance.Pf.TitleLarge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/icon_children_chevron"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/text_my_children_body"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:text="@string/home_children_card_body"
                    android:textAppearance="@style/TextAppearance.Pf.BodyMedium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/icon_children_chevron"
                    app:layout_constraintTop_toBottomOf="@id/text_my_children_title" />

                <ImageView
                    android:id="@+id/icon_children_chevron"
                    android:layout_width="@dimen/spacing_12"
                    android:layout_height="@dimen/spacing_12"
                    android:layout_marginStart="@dimen/spacing_4"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:tint="?attr/colorOnSurfaceVariant" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

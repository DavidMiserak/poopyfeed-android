<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_page"
    android:fillViewport="true"
    tools:context=".AccountSettingsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_8">

        <!-- Decorative background blobs -->
        <View
            android:id="@+id/blob_rose"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_blob_rose"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="-40dp"
            android:layout_marginStart="-40dp" />

        <View
            android:id="@+id/blob_orange"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:background="@drawable/bg_blob_orange"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="-60dp"
            android:layout_marginEnd="-60dp" />

        <!-- Page title -->
        <TextView
            android:id="@+id/text_account_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16"
            android:text="@string/account_settings_title"
            android:textAppearance="@style/TextAppearance.Pf.HeadlineSmall"
            android:textAlignment="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Account settings card (frosted glass) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_account"
            style="@style/Widget.Pf.CardView.Frosted"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_account_title">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_12">

                <!-- Email (read-only) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_account_email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/account_email_label"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
                    app:boxStrokeColor="@color/rose_400"
                    app:hintTextColor="@color/rose_400"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_account_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:fontFamily="@font/dm_sans" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- First name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_account_first_name"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:hint="@string/account_first_name_label"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
                    app:boxStrokeColor="@color/rose_400"
                    app:hintTextColor="@color/rose_400"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/input_layout_account_email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_account_first_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"
                        android:fontFamily="@font/dm_sans" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Last name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_account_last_name"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:hint="@string/account_last_name_label"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
                    app:boxStrokeColor="@color/rose_400"
                    app:hintTextColor="@color/rose_400"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/input_layout_account_first_name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_account_last_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:imeOptions="actionNext"
                        android:fontFamily="@font/dm_sans" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Timezone (dropdown) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_account_timezone"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:hint="@string/account_timezone_label"
                    android:labelFor="@+id/auto_complete_account_timezone"
                    app:endIconMode="dropdown_menu"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
                    app:boxStrokeColor="@color/rose_400"
                    app:hintTextColor="@color/rose_400"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/input_layout_account_last_name">

                    <AutoCompleteTextView
                        android:id="@+id/auto_complete_account_timezone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:fontFamily="@font/dm_sans" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Save button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_account_save"
                    style="@style/Widget.Pf.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:text="@string/account_save_button"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/input_layout_account_timezone" />

                <!-- Loading indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_account"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_6"
                    android:visibility="gone"
                    android:indeterminate="true"
                    app:indicatorColor="@color/rose_400"
                    app:trackColor="@color/rose_100"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/button_account_save" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

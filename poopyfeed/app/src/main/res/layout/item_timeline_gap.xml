<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingVertical="@dimen/spacing_4">

    <!-- Gap duration row with dashed lines -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_4">

        <!-- Left dashed line -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_6"
            android:alpha="0.25"
            android:background="@drawable/bg_dashed_line" />

        <!-- Gap duration label with sleep emoji -->
        <TextView
            android:id="@+id/text_gap_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/dm_sans"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_label_small"
            tools:text="💤 2h 30m quiet" />

        <!-- Right dashed line -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_6"
            android:alpha="0.25"
            android:background="@drawable/bg_dashed_line" />

    </LinearLayout>

    <!-- Add nap button with time range hint -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_nap"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginTop="@dimen/spacing_4"
        android:fontFamily="@font/dm_sans"
        android:textSize="@dimen/text_label_small"
        android:textColor="?attr/colorOnTertiaryContainer"
        app:backgroundTint="?attr/colorTertiaryContainer"
        app:iconTint="?attr/colorOnTertiaryContainer"
        app:cornerRadius="@dimen/corner_radius_md"
        tools:text="😴 Add nap · 2:30 – 4:15 PM" />

</LinearLayout>

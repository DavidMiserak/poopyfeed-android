<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:elevation="@dimen/elevation_4"
        android:fitsSystemWindows="true">

        <!-- Gradient accent line (rose → orange → amber) at the top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="?attr/colorPrimary" />

        <!-- Toolbar with heart logo + branded title -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            app:elevation="0dp"
            app:titleTextColor="?attr/colorOnSurface">

            <!-- Custom toolbar content: heart + title (currently hidden in favor of Navigation-driven title) -->
            <LinearLayout
                android:id="@+id/brand_mark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_4"
                    android:text="@string/app_name"
                    android:fontFamily="@font/fredoka"
                    android:textSize="22sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Timezone mismatch banner — bold, refined design with gradient + left accent -->
        <LinearLayout
            android:id="@+id/banner_timezone_mismatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="?attr/colorSurfaceContainerHigh"
            android:orientation="horizontal"
            android:paddingStart="0dp"
            android:paddingEnd="@dimen/spacing_8"
            android:paddingTop="@dimen/spacing_6"
            android:paddingBottom="@dimen/spacing_6"
            android:gravity="center_vertical">

            <!-- Left accent stripe (rose to orange gradient) -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="?attr/colorPrimary" />

            <!-- Main content container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_8"
                android:paddingVertical="@dimen/spacing_4">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/timezone_mismatch_title"
                    android:fontFamily="@font/fredoka"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/text_timezone_mismatch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>

            <!-- Action buttons container (horizontal) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:spacing="@dimen/spacing_4">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_timezone_banner"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone"
                    app:indicatorColor="?attr/colorPrimary"
                    app:trackColor="@android:color/transparent"
                    app:indicatorSize="20dp" />

                <!-- Primary action button (prominent) -->
                <Button
                    android:id="@+id/button_use_device_timezone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:paddingHorizontal="@dimen/spacing_6"
                    android:paddingVertical="@dimen/spacing_3"
                    android:contentDescription="@string/a11y_use_device_timezone"
                    android:text="@string/timezone_use_device"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans"
                    android:textColor="?attr/colorOnPrimary"
                    android:background="?attr/colorPrimary" />

                <!-- Secondary action button (subtle) -->
                <Button
                    android:id="@+id/button_dismiss_timezone_banner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:paddingHorizontal="@dimen/spacing_4"
                    android:paddingVertical="@dimen/spacing_3"
                    android:contentDescription="@string/a11y_dismiss"
                    android:text="@string/dismiss"
                    android:textSize="11sp"
                    android:fontFamily="@font/dm_sans"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:background="@android:color/transparent"
                    android:foreground="?attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/colorSurface">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment_content_main"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_graph" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            style="@style/Widget.Pf.FloatingActionButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="@dimen/spacing_8"
            android:layout_marginBottom="@dimen/spacing_8"
            android:contentDescription="@string/fab_description"
            app:srcCompat="@drawable/ic_plus" />

    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="@dimen/elevation_4"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</LinearLayout>

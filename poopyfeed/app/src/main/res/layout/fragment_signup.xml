<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_page"
    android:fillViewport="true"
    tools:context="net.poopyfeed.pf.accounts.SignupFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_8">

        <!-- Decorative background blobs -->
        <View
            android:id="@+id/blob_rose"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:background="@drawable/bg_blob_rose"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="-40dp"
            android:layout_marginStart="-40dp" />

        <View
            android:id="@+id/blob_orange"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:background="@drawable/bg_blob_orange"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="-60dp"
            android:layout_marginEnd="-60dp" />

        <!-- Brand mark: heart + title -->
        <LinearLayout
            android:id="@+id/brand_mark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_16"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_home"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_4"
                android:text="@string/signup_title"
                android:textSize="36sp"
                android:fontFamily="@font/fredoka"
                android:textColor="@color/rose_400"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/text_signup_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:text="@string/signup_subtitle"
            android:textAppearance="@style/TextAppearance.Pf.BodyLarge"
            android:textAlignment="center"
            android:paddingHorizontal="@dimen/spacing_8"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/brand_mark" />

        <!-- Sign-up card (frosted glass) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_signup"
            style="@style/Widget.Pf.CardView.Frosted"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_signup_subtitle">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_12">

                <!-- Card title -->
                <TextView
                    android:id="@+id/text_signup_card_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/signup_card_title"
                    android:textAppearance="@style/TextAppearance.Pf.HeadlineSmall"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Card subtitle -->
                <TextView
                    android:id="@+id/text_signup_card_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:text="@string/signup_card_subtitle"
                    android:textAppearance="@style/TextAppearance.Pf.BodyMedium"
                    android:textColor="@color/slate_600"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_signup_card_title" />

                <!-- Email input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_signup_email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:hint="@string/signup_email_label"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
                    app:boxStrokeColor="@color/rose_400"
                    app:hintTextColor="@color/rose_400"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_signup_card_subtitle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_signup_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionNext"
                        android:textColor="@color/slate_900"
                        android:fontFamily="@font/dm_sans" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_signup_password"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:hint="@string/signup_password_label"
                    app:endIconMode="password_toggle"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
                    app:boxStrokeColor="@color/rose_400"
                    app:hintTextColor="@color/rose_400"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/input_layout_signup_email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_signup_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionNext"
                        android:textColor="@color/slate_900"
                        android:fontFamily="@font/dm_sans" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Confirm password input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_layout_signup_confirm_password"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:hint="@string/signup_confirm_password_label"
                    app:endIconMode="password_toggle"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
                    app:boxStrokeColor="@color/rose_400"
                    app:hintTextColor="@color/rose_400"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/input_layout_signup_password">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_text_signup_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:textColor="@color/slate_900"
                        android:fontFamily="@font/dm_sans" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Sign up button (gradient) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_signup"
                    style="@style/Widget.Pf.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_8"
                    android:text="@string/signup_button"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/input_layout_signup_confirm_password" />

                <!-- Loading indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_signup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_6"
                    android:visibility="gone"
                    android:indeterminate="true"
                    app:indicatorColor="@color/rose_400"
                    app:trackColor="@color/rose_100"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/button_signup" />

                <!-- Already have an account -->
                <TextView
                    android:id="@+id/text_go_to_login"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_6"
                    android:text="@string/signup_go_to_login"
                    android:textAppearance="@style/TextAppearance.Pf.BodyMedium"
                    android:textColor="@color/rose_400"
                    android:gravity="center"
                    android:paddingVertical="@dimen/spacing_2"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/progress_signup" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

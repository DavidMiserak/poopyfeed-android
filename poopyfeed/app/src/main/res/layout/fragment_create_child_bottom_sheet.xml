<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_12"
    tools:context="net.poopyfeed.pf.children.CreateChildBottomSheetFragment">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/spacing_8"
        android:background="@drawable/ic_drag_handle"
        android:alpha="0.3" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/create_child_title"
        android:fontFamily="@font/fredoka"
        android:textSize="@dimen/text_title_large"
        android:textColor="@color/slate_900"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_8" />

    <!-- Name field -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_8"
        android:hint="@string/create_child_name_label"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
        app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
        app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
        app:boxCornerRadiusTopStart="@dimen/corner_radius_md">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/slate_900"
            android:fontFamily="@font/dm_sans" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- DOB field -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layout_dob"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_8"
        android:hint="@string/create_child_dob_label"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="@dimen/corner_radius_md"
        app:boxCornerRadiusBottomStart="@dimen/corner_radius_md"
        app:boxCornerRadiusTopEnd="@dimen/corner_radius_md"
        app:boxCornerRadiusTopStart="@dimen/corner_radius_md">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_dob"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="date"
            android:focusable="false"
            android:clickable="true"
            android:textColor="@color/slate_900"
            android:fontFamily="@font/dm_sans" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Gender label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/create_child_gender_label"
        android:fontFamily="@font/dm_sans"
        android:textSize="@dimen/text_body_medium"
        android:textColor="@color/slate_900"
        android:layout_marginTop="@dimen/spacing_4"
        android:layout_marginBottom="@dimen/spacing_2" />

    <!-- Gender RadioGroup -->
    <RadioGroup
        android:id="@+id/radio_gender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_8">

        <RadioButton
            android:id="@+id/radio_boy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/create_child_gender_male"
            android:fontFamily="@font/dm_sans"
            android:textSize="@dimen/text_body_medium"
            android:buttonTint="@color/rose_400" />

        <RadioButton
            android:id="@+id/radio_girl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/create_child_gender_female"
            android:fontFamily="@font/dm_sans"
            android:textSize="@dimen/text_body_medium"
            android:buttonTint="@color/rose_400" />

    </RadioGroup>

    <!-- Save button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_4">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_save"
            style="@style/Widget.Pf.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/create_child_save_button"
            android:layout_gravity="center" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_saving"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context="net.poopyfeed.pf.children.ChildDetailQuickLogBottomSheetFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_12"
        android:paddingEnd="@dimen/spacing_12"
        android:paddingTop="@dimen/spacing_6"
        android:paddingBottom="@dimen/spacing_16">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/spacing_8"
            android:background="@drawable/ic_drag_handle"
            android:alpha="0.35" />

        <!-- Title block -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_2"
            android:fontFamily="@font/fredoka"
            android:text="@string/quick_log_sheet_title"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/text_title_large"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            android:fontFamily="@font/dm_sans"
            android:text="@string/quick_log_sheet_subtitle"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_body_small" />

        <!-- Section 1: Nap (tertiary accent) – at top -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Pf.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="56dp">

                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorTertiary"
                    android:alpha="0.75" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_4"
                        android:fontFamily="@font/dm_sans_medium"
                        android:text="@string/quick_log_nap_section_label"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/text_label_small" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_log_nap"
                        style="@style/Widget.Pf.Button.Secondary.Bordered"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/create_nap_title" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section 2: Bottle (primary accent) -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Pf.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="56dp">

                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorPrimary"
                    android:alpha="0.75" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_4"
                        android:fontFamily="@font/dm_sans_medium"
                        android:text="@string/create_feeding_amount_label"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/text_label_small" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_bottle_low"
                            style="@style/Widget.Pf.Button.Secondary.Bordered"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_2"
                            android:minHeight="48dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/spacing_2"
                            android:paddingEnd="@dimen/spacing_2"
                            android:textSize="@dimen/text_body_medium"
                            tools:text="2 oz" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_bottle_mid"
                            style="@style/Widget.Pf.Button.Primary.Bordered"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_1"
                            android:layout_marginEnd="@dimen/spacing_1"
                            android:minHeight="48dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/spacing_2"
                            android:paddingEnd="@dimen/spacing_2"
                            android:textSize="@dimen/text_body_medium"
                            tools:text="4 oz" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_bottle_high"
                            style="@style/Widget.Pf.Button.Secondary.Bordered"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_2"
                            android:minHeight="48dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/spacing_2"
                            android:paddingEnd="@dimen/spacing_2"
                            android:textSize="@dimen/text_body_medium"
                            tools:text="6 oz" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section 3: Diaper (secondary accent) -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Pf.CardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_8"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:minHeight="56dp">

                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSecondary"
                    android:alpha="0.75" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_4"
                        android:fontFamily="@font/dm_sans_medium"
                        android:text="@string/create_diaper_type_label"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/text_label_small" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_diaper_wet"
                            style="@style/Widget.Pf.Button.Secondary.Bordered"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_2"
                            android:minHeight="48dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/spacing_2"
                            android:paddingEnd="@dimen/spacing_2"
                            android:textSize="@dimen/text_body_small"
                            android:text="@string/diaper_change_wet" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_diaper_dirty"
                            style="@style/Widget.Pf.Button.Secondary.Bordered"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_1"
                            android:layout_marginEnd="@dimen/spacing_1"
                            android:minHeight="48dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/spacing_2"
                            android:paddingEnd="@dimen/spacing_2"
                            android:textSize="@dimen/text_body_small"
                            android:text="@string/diaper_change_dirty" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/button_diaper_both"
                            style="@style/Widget.Pf.Button.Secondary.Bordered"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_2"
                            android:minHeight="48dp"
                            android:minWidth="0dp"
                            android:paddingStart="@dimen/spacing_2"
                            android:paddingEnd="@dimen/spacing_2"
                            android:textSize="@dimen/text_body_small"
                            android:text="@string/diaper_change_both" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

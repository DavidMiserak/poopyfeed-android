<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_page"
    tools:context="net.poopyfeed.pf.reports.PediatricianSummaryFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_6"
            android:paddingEnd="@dimen/spacing_6"
            android:paddingTop="@dimen/spacing_6"
            android:paddingBottom="@dimen/bottom_nav_inset">

            <ProgressBar
                android:id="@+id/progress_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_16"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:gravity="center"
                android:fontFamily="@font/dm_sans"
                android:textColor="?attr/colorError"
                android:textSize="@dimen/text_body_medium"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_16"
                android:gravity="center"
                android:fontFamily="@font/dm_sans"
                android:text="@string/pediatrician_empty"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_body_medium"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layout_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/text_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fredoka"
                    android:text="@string/pediatrician_period"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_body_small"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Pf.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/fredoka"
                            android:text="@string/pediatrician_feedings_label"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_body_medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_feedings_per_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_medium"
                            tools:text="5/day" />

                        <TextView
                            android:id="@+id/text_oz_per_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small"
                            tools:text="12.5 oz/day" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Pf.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_4">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/fredoka"
                            android:text="@string/pediatrician_diapers_label"
                            android:textColor="?attr/colorSecondary"
                            android:textSize="@dimen/text_body_medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_diapers_per_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_medium"
                            tools:text="4/day" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Pf.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/fredoka"
                            android:text="@string/pediatrician_naps_label"
                            android:textColor="?attr/colorTertiary"
                            android:textSize="@dimen/text_body_medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_naps_per_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="@dimen/text_body_medium"
                            tools:text="2/day" />

                        <TextView
                            android:id="@+id/text_sleep_per_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/dm_sans"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="@dimen/text_body_small"
                            tools:text="2h total sleep/day" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Pf.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:layout_marginStart="@dimen/spacing_0"
    android:layout_marginEnd="@dimen/spacing_0"
    android:layout_marginTop="@dimen/spacing_3"
    android:layout_marginBottom="@dimen/spacing_3"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_12"
        android:paddingEnd="@dimen/spacing_8"
        android:paddingTop="@dimen/spacing_8"
        android:paddingBottom="@dimen/spacing_8">

        <!-- LEFT COLUMN: Name, Age/Gender, Activity Summary -->

        <!-- Child name -->
        <TextView
            android:id="@+id/text_child_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fredoka"
            android:textSize="@dimen/text_headline_small"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/layout_right_column"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_bias="0"
            tools:text="Baby Alice" />

        <!-- Age and gender line -->
        <TextView
            android:id="@+id/text_age_gender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_1"
            android:fontFamily="@font/dm_sans"
            android:textSize="@dimen/text_body_medium"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/layout_right_column"
            app:layout_constraintTop_toBottomOf="@id/text_child_name"
            tools:text="3 months • Girl" />

        <!-- RIGHT COLUMN: Role Chip + Vertical Activity Dots -->

        <!-- Container for role chip and activity dots -->
        <LinearLayout
            android:id="@+id/layout_right_column"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:spacing="@dimen/spacing_2"
            android:gravity="end"
            android:layout_marginStart="@dimen/spacing_8"
            app:layout_constraintEnd_toStartOf="@id/icon_chevron"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Role badge (hidden for owner) -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_role_badge"
                android:textSize="@dimen/text_label_small"
                app:chipBackgroundColor="?attr/colorSecondaryContainer"
                app:chipIcon="@drawable/ic_person"
                app:chipIconSize="@dimen/spacing_4"
                android:visibility="gone" />

            <!-- Activity indicators (tabular, right-aligned for quick scanning) -->
            <LinearLayout
                android:id="@+id/layout_activity_indicators"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:spacing="@dimen/spacing_2"
                android:gravity="end">

                <!-- Feeding row: emoji + label [padding] time -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:spacing="@dimen/spacing_2"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍼"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="Feeding"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/text_last_feeding"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="end"
                        tools:text="17h" />

                </LinearLayout>

                <!-- Diaper row: emoji + label [padding] time -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:spacing="@dimen/spacing_2"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💩"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="Diaper"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/text_last_diaper"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="end"
                        tools:text="17h" />

                </LinearLayout>

                <!-- Nap row: emoji + label [padding] time -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:spacing="@dimen/spacing_2"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😴"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:text="Nap"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/text_last_nap"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_small"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="end"
                        tools:text="22h" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Chevron icon -->
        <ImageView
            android:id="@+id/icon_chevron"
            android:layout_width="@dimen/spacing_12"
            android:layout_height="@dimen/spacing_12"
            android:layout_marginStart="@dimen/spacing_4"
            android:scaleType="centerInside"
            android:src="@drawable/ic_chevron_right"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="?attr/colorOnSurfaceVariant" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

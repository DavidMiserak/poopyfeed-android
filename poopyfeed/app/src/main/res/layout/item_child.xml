<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Pf.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:layout_marginStart="@dimen/spacing_0"
    android:layout_marginEnd="@dimen/spacing_0"
    android:layout_marginTop="@dimen/spacing_3"
    android:layout_marginBottom="@dimen/spacing_3"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_12"
        android:paddingEnd="@dimen/spacing_8"
        android:paddingTop="@dimen/spacing_8"
        android:paddingBottom="@dimen/spacing_8">

        <!-- Child name -->
        <TextView
            android:id="@+id/text_child_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/fredoka"
            android:textSize="@dimen/text_headline_small"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chip_role"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_bias="0"
            tools:text="Baby Alice" />

        <!-- Age and gender line -->
        <TextView
            android:id="@+id/text_age_gender"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_1"
            android:fontFamily="@font/dm_sans"
            android:textSize="@dimen/text_body_medium"
            android:textColor="?attr/colorOnSurfaceVariant"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chip_role"
            app:layout_constraintTop_toBottomOf="@id/text_child_name"
            tools:text="3 months • Girl" />

        <!-- Activity badges container (horizontal flex) -->
        <LinearLayout
            android:id="@+id/layout_activities"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:orientation="horizontal"
            android:spacing="@dimen/spacing_4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/chip_role"
            app:layout_constraintTop_toBottomOf="@id/text_age_gender">

            <!-- Feeding badge -->
            <LinearLayout
                android:id="@+id/badge_feeding"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_4"
                android:paddingVertical="@dimen/spacing_3"
                android:background="@drawable/bg_badge_feeding"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/icon_feeding"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/badge_icon_feeding"
                    android:textSize="@dimen/text_badge_icon"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/text_last_feeding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="@dimen/text_label_small"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:lines="2"
                    tools:text="4m ago" />

            </LinearLayout>

            <!-- Diaper badge -->
            <LinearLayout
                android:id="@+id/badge_diaper"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_4"
                android:paddingVertical="@dimen/spacing_3"
                android:background="@drawable/bg_badge_diaper"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/icon_diaper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/badge_icon_diaper"
                    android:textSize="@dimen/text_badge_icon"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/text_last_diaper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="@dimen/text_label_small"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:lines="2"
                    tools:text="22h ago" />

            </LinearLayout>

            <!-- Nap badge -->
            <LinearLayout
                android:id="@+id/badge_nap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_4"
                android:paddingVertical="@dimen/spacing_3"
                android:background="@drawable/bg_badge_nap"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/icon_nap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/badge_icon_nap"
                    android:textSize="@dimen/text_badge_icon"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/text_last_nap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="@dimen/text_label_small"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"
                    android:lines="2"
                    tools:text="8h ago" />

            </LinearLayout>

        </LinearLayout>

        <!-- Role badge (hidden for owner) -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_4"
            android:text="@string/child_role_badge"
            android:textSize="@dimen/text_label_small"
            app:chipBackgroundColor="?attr/colorSecondaryContainer"
            app:chipIcon="@drawable/ic_person"
            app:chipIconSize="@dimen/spacing_4"
            app:layout_constraintEnd_toStartOf="@id/icon_chevron"
            app:layout_constraintTop_toTopOf="parent"
            android:visibility="gone" />

        <!-- Chevron icon -->
        <ImageView
            android:id="@+id/icon_chevron"
            android:layout_width="@dimen/spacing_12"
            android:layout_height="@dimen/spacing_12"
            android:layout_marginStart="@dimen/spacing_4"
            android:scaleType="centerInside"
            android:src="@drawable/ic_chevron_right"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:tint="?attr/colorOnSurfaceVariant" />

        <!-- Subtle bottom divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/divider_thickness"
            android:background="?attr/colorOutline"
            android:alpha="0.15"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

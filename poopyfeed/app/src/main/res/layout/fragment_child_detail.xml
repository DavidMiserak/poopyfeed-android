<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    tools:context="net.poopyfeed.pf.children.ChildDetailFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_6"
        android:paddingEnd="@dimen/spacing_6"
        android:paddingTop="@dimen/spacing_6"
        android:paddingBottom="@dimen/bottom_nav_inset">

        <!-- Hero banner card (refined, minimal elevation) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_0"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorPrimaryContainer"
                android:paddingStart="@dimen/spacing_12"
                android:paddingEnd="@dimen/spacing_12"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12">

                <!-- Avatar emoji -->
                <TextView
                    android:id="@+id/text_avatar_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶"
                    android:textSize="48sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="Hardcoded" />

                <!-- Child name -->
                <TextView
                    android:id="@+id/text_child_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:fontFamily="@font/fredoka"
                    android:textSize="@dimen/text_headline_medium"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_actions"
                    app:layout_constraintTop_toBottomOf="@id/text_avatar_emoji"
                    tools:text="Baby Alice" />

                <!-- Age and gender -->
                <TextView
                    android:id="@+id/text_age_gender"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="@dimen/text_body_large"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_actions"
                    app:layout_constraintTop_toBottomOf="@id/text_child_name"
                    tools:text="3 months • Girl" />

                <!-- Right column: Role chip + action buttons -->
                <LinearLayout
                    android:id="@+id/layout_actions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:spacing="@dimen/spacing_4"
                    android:gravity="end"
                    android:layout_marginStart="@dimen/spacing_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Role badge (hidden for owner) -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Co-parent"
                        android:textSize="@dimen/text_label_small"
                        app:chipBackgroundColor="?attr/colorSecondaryContainer"
                        app:chipIcon="@drawable/ic_person"
                        app:chipIconSize="@dimen/spacing_4"
                        android:visibility="gone" />

                    <!-- Edit button (owner / co-parent) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_edit"
                        style="@style/Widget.Pf.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_detail_edit_button"
                        android:contentDescription="@string/child_detail_edit_button"
                        android:visibility="gone" />

                    <!-- Share button (owner only) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_share"
                        style="@style/Widget.Pf.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_detail_share_button"
                        android:contentDescription="@string/child_detail_share_button"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Activity status: consolidated single card with accent stripe -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_activity_status"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_hero">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Single accent stripe for whole card -->
                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorPrimary"
                    android:alpha="0.7" />

                <!-- Rows container -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Feeding row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8"
                        android:paddingTop="@dimen/spacing_6"
                        android:paddingBottom="@dimen/spacing_6">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍼"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:text="Last Feeding"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/label_feeding"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="end"
                            tools:text="2h ago" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:background="?attr/colorSurfaceVariant"
                        android:alpha="0.3" />

                    <!-- Diaper row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8"
                        android:paddingTop="@dimen/spacing_6"
                        android:paddingBottom="@dimen/spacing_6">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💩"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:text="Last Diaper"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/label_diaper"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="end"
                            tools:text="30m ago" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:background="?attr/colorSurfaceVariant"
                        android:alpha="0.3" />

                    <!-- Nap row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8"
                        android:paddingTop="@dimen/spacing_6"
                        android:paddingBottom="@dimen/spacing_6">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😴"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:text="Last Nap"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/label_nap"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="end"
                            tools:text="1h ago" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Tracking shortcuts (action buttons with better spacing) -->
        <LinearLayout
            android:id="@+id/card_tracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:orientation="vertical"
            android:spacing="@dimen/spacing_4"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_activity_status">

            <!-- Feedings navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_feedings"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorPrimary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍼"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_feedings"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Diapers navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_diapers"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorSecondary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💩"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_diapers"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Naps navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_naps"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorTertiary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😴"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_naps"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

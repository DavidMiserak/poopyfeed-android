<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_page"
    android:fillViewport="true"
    tools:context="net.poopyfeed.pf.children.ChildDetailFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_6"
        android:paddingEnd="@dimen/spacing_6"
        android:paddingTop="@dimen/spacing_6"
        android:paddingBottom="@dimen/bottom_nav_inset"
        tools:ignore="TooManyViews,NestedWeights">

        <!-- Full skeleton: visible when Loading (no child yet). Same approximate layout to avoid CLS. -->
        <LinearLayout
            android:id="@+id/layout_skeleton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="@dimen/spacing_0"
            android:paddingEnd="@dimen/spacing_0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible">

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5" />
            <View
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5" />
            <View
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5"
                android:contentDescription="@string/child_detail_today_loading" />
            <View
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5" />
        </LinearLayout>

        <!-- Hero banner card (refined, minimal elevation) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_0"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorPrimaryContainer"
                android:paddingStart="@dimen/spacing_12"
                android:paddingEnd="@dimen/spacing_12"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12">

                <!-- Avatar emoji -->
                <TextView
                    android:id="@+id/text_avatar_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_baby"
                    android:textSize="48sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Child name -->
                <TextView
                    android:id="@+id/text_child_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:fontFamily="@font/fredoka"
                    android:textSize="@dimen/text_headline_medium"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_actions"
                    app:layout_constraintTop_toBottomOf="@id/text_avatar_emoji"
                    tools:text="Baby Alice" />

                <!-- Age and gender -->
                <TextView
                    android:id="@+id/text_age_gender"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="@dimen/text_body_large"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_actions"
                    app:layout_constraintTop_toBottomOf="@id/text_child_name"
                    tools:text="3 months • Girl" />

                <!-- Right column: Role chip + action buttons -->
                <LinearLayout
                    android:id="@+id/layout_actions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:spacing="@dimen/spacing_4"
                    android:gravity="end"
                    android:layout_marginStart="@dimen/spacing_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Role badge (hidden for owner) -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sharing_role_co_parent"
                        android:textSize="@dimen/text_label_small"
                        app:chipBackgroundColor="?attr/colorSecondaryContainer"
                        app:chipIcon="@drawable/ic_person"
                        app:chipIconSize="@dimen/spacing_4"
                        android:visibility="gone" />

                    <!-- Edit button (owner / co-parent) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_edit"
                        style="@style/Widget.Pf.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_detail_edit_button"
                        android:contentDescription="@string/child_detail_edit_button"
                        android:visibility="gone" />

                    <!-- Share button (owner only) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_share"
                        style="@style/Widget.Pf.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_detail_share_button"
                        android:contentDescription="@string/child_detail_share_button"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Section: Recent Activity -->
        <TextView
            android:id="@+id/label_recent_activity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:layout_marginBottom="@dimen/spacing_4"
            android:fontFamily="@font/fredoka"
            android:text="@string/child_detail_section_recent_activity"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_body_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_hero" />

        <!-- Feeding card (tappable) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_feeding"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/label_recent_activity">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorPrimary"
                    android:alpha="0.7" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/badge_icon_feeding"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_4"
                        android:text="@string/child_detail_last_feeding_title"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_medium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/label_feeding"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_medium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="end"
                        tools:text="2h ago" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Diapers card (tappable) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_diaper"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_feeding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSecondary"
                    android:alpha="0.7" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/badge_icon_diaper"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_4"
                        android:text="@string/child_detail_last_diaper_title"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_medium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/label_diaper"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_medium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="end"
                        tools:text="30m ago" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Naps card (tappable) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_nap"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_diaper">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorTertiary"
                    android:alpha="0.7" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/badge_icon_nap"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_4"
                        android:text="@string/child_detail_last_nap_title"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_medium"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/label_nap"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_medium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="end"
                        tools:text="1h ago" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Pattern alerts card (feeding and nap warnings) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_pattern_alerts"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_nap">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Amber accent stripe -->
                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorTertiary"
                    android:alpha="0.9" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <!-- Feeding alert row -->
                    <LinearLayout
                        android:id="@+id/row_feeding_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/icon_warning"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/text_feeding_alert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="Baby usually feeds every 3h — it's been 3h 30m" />
                    </LinearLayout>

                    <!-- Nap alert row (with margin if both are shown) -->
                    <LinearLayout
                        android:id="@+id/row_nap_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/spacing_4"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/icon_warning"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/text_nap_alert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="Baby usually naps after ~2h awake — awake for 2h 30m" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Today summary card (batch dashboard-summary); skeleton shown until loaded -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_today"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            app:layout_goneMarginTop="@dimen/spacing_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_pattern_alerts">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="72dp">

                <!-- Skeleton: visible while dashboardSummary is null -->
                <View
                    android:id="@+id/today_skeleton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:minHeight="96dp"
                    android:background="?attr/colorSurfaceVariant"
                    android:alpha="0.6"
                    android:contentDescription="@string/child_detail_today_loading"
                    android:importantForAccessibility="yes" />

                <!-- Real counts: three stat columns -->
                <LinearLayout
                    android:id="@+id/today_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <!-- Section label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8"
                        android:paddingTop="@dimen/spacing_6"
                        android:fontFamily="@font/fredoka"
                        android:text="@string/child_detail_today_label"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/text_body_small" />

                    <!-- Stat columns row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/spacing_4"
                        android:paddingEnd="@dimen/spacing_4"
                        android:paddingTop="@dimen/spacing_4"
                        android:paddingBottom="@dimen/spacing_6"
                        android:baselineAligned="false">

                        <!-- Feedings stat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingTop="@dimen/spacing_2"
                            android:paddingBottom="@dimen/spacing_2">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/badge_icon_feeding"
                                android:textSize="22sp" />

                            <TextView
                                android:id="@+id/text_today_feedings_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/fredoka"
                                android:textSize="@dimen/text_headline_small"
                                android:textColor="?attr/colorPrimary"
                                android:textStyle="bold"
                                tools:text="5" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:text="@string/child_detail_today_feedings"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/text_body_small" />

                            <TextView
                                android:id="@+id/text_today_feedings_detail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_1"
                                android:fontFamily="@font/dm_sans"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_label_small"
                                tools:text="12.5 oz" />

                        </LinearLayout>

                        <!-- Vertical divider -->
                        <View
                            android:layout_width="@dimen/divider_thickness"
                            android:layout_height="match_parent"
                            android:layout_marginTop="@dimen/spacing_4"
                            android:layout_marginBottom="@dimen/spacing_4"
                            android:background="?attr/colorOutline"
                            android:alpha="0.4" />

                        <!-- Diapers stat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingTop="@dimen/spacing_2"
                            android:paddingBottom="@dimen/spacing_2">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/badge_icon_diaper"
                                android:textSize="22sp" />

                            <TextView
                                android:id="@+id/text_today_diapers_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/fredoka"
                                android:textSize="@dimen/text_headline_small"
                                android:textColor="?attr/colorSecondary"
                                android:textStyle="bold"
                                tools:text="3" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:text="@string/child_detail_today_diapers"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/text_body_small" />

                            <TextView
                                android:id="@+id/text_today_diapers_detail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_1"
                                android:fontFamily="@font/dm_sans"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_label_small"
                                tools:text="2 wet, 1 dirty, 1 both" />

                        </LinearLayout>

                        <!-- Vertical divider -->
                        <View
                            android:layout_width="@dimen/divider_thickness"
                            android:layout_height="match_parent"
                            android:layout_marginTop="@dimen/spacing_4"
                            android:layout_marginBottom="@dimen/spacing_4"
                            android:background="?attr/colorOutline"
                            android:alpha="0.4" />

                        <!-- Naps stat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:paddingTop="@dimen/spacing_2"
                            android:paddingBottom="@dimen/spacing_2">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/badge_icon_nap"
                                android:textSize="22sp" />

                            <TextView
                                android:id="@+id/text_today_naps_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/fredoka"
                                android:textSize="@dimen/text_headline_small"
                                android:textColor="?attr/colorTertiary"
                                android:textStyle="bold"
                                tools:text="2" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/dm_sans"
                                android:text="@string/child_detail_today_naps"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="@dimen/text_body_small" />

                            <TextView
                                android:id="@+id/text_today_naps_detail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/spacing_1"
                                android:fontFamily="@font/dm_sans"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_label_small"
                                tools:text="1h 45m total" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section: Track -->
        <TextView
            android:id="@+id/label_track"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16"
            android:layout_marginBottom="@dimen/spacing_4"
            android:fontFamily="@font/fredoka"
            android:text="@string/child_detail_section_track"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/text_body_medium"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_today" />

        <!-- Tracking shortcuts (action buttons) -->
        <LinearLayout
            android:id="@+id/card_tracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_4"
            android:orientation="vertical"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/label_track">

            <!-- Feedings navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_feedings"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:contentDescription="@string/a11y_go_to_feedings"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorPrimary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_icon_feeding"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_feedings"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Diapers navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_diapers"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/spacing_4"
                android:contentDescription="@string/a11y_go_to_diapers"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorSecondary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_icon_diaper"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_diapers"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Naps navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_naps"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="@dimen/spacing_4"
                android:contentDescription="@string/a11y_go_to_naps"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorTertiary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_icon_nap"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_naps"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


        <!-- Reports card (gradient hero style) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/button_reports"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_16"
            android:contentDescription="@string/a11y_go_to_reports"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_tracking">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_hero"
                android:paddingStart="@dimen/spacing_12"
                android:paddingEnd="@dimen/spacing_12"
                android:paddingTop="@dimen/spacing_8"
                android:paddingBottom="@dimen/spacing_8">

                <TextView
                    android:id="@+id/reports_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/icon_reports"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/reports_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:fontFamily="@font/fredoka"
                    android:text="@string/child_detail_reports"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/reports_emoji"
                    app:layout_constraintEnd_toStartOf="@id/reports_chevron"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/reports_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_8"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:fontFamily="@font/dm_sans"
                    android:text="@string/child_detail_reports_subtitle"
                    android:textColor="@android:color/white"
                    android:alpha="0.85"
                    android:textSize="@dimen/text_body_small"
                    app:layout_constraintStart_toEndOf="@id/reports_emoji"
                    app:layout_constraintEnd_toStartOf="@id/reports_chevron"
                    app:layout_constraintTop_toBottomOf="@id/reports_title" />

                <ImageView
                    android:id="@+id/reports_chevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    app:tint="@android:color/white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>

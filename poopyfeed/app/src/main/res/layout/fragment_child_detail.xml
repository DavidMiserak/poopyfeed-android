<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    tools:context="net.poopyfeed.pf.children.ChildDetailFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_6"
        android:paddingEnd="@dimen/spacing_6"
        android:paddingTop="@dimen/spacing_6"
        android:paddingBottom="@dimen/bottom_nav_inset">

        <!-- Full skeleton: visible when Loading (no child yet). Same approximate layout to avoid CLS. -->
        <LinearLayout
            android:id="@+id/layout_skeleton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="@dimen/spacing_0"
            android:paddingEnd="@dimen/spacing_0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible">

            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5" />
            <View
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5" />
            <View
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5"
                android:contentDescription="@string/child_detail_today_loading" />
            <View
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/spacing_12"
                android:background="?attr/colorSurfaceVariant"
                android:alpha="0.5" />
        </LinearLayout>

        <!-- Hero banner card (refined, minimal elevation) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_0"
            app:cardCornerRadius="@dimen/corner_radius_lg"
            app:cardElevation="@dimen/elevation_2"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/colorPrimaryContainer"
                android:paddingStart="@dimen/spacing_12"
                android:paddingEnd="@dimen/spacing_12"
                android:paddingTop="@dimen/spacing_12"
                android:paddingBottom="@dimen/spacing_12">

                <!-- Avatar emoji -->
                <TextView
                    android:id="@+id/text_avatar_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👶"
                    android:textSize="48sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:ignore="Hardcoded" />

                <!-- Child name -->
                <TextView
                    android:id="@+id/text_child_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:fontFamily="@font/fredoka"
                    android:textSize="@dimen/text_headline_medium"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_actions"
                    app:layout_constraintTop_toBottomOf="@id/text_avatar_emoji"
                    tools:text="Baby Alice" />

                <!-- Age and gender -->
                <TextView
                    android:id="@+id/text_age_gender"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:fontFamily="@font/dm_sans"
                    android:textSize="@dimen/text_body_large"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/layout_actions"
                    app:layout_constraintTop_toBottomOf="@id/text_child_name"
                    tools:text="3 months • Girl" />

                <!-- Right column: Role chip + action buttons -->
                <LinearLayout
                    android:id="@+id/layout_actions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:spacing="@dimen/spacing_4"
                    android:gravity="end"
                    android:layout_marginStart="@dimen/spacing_12"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <!-- Role badge (hidden for owner) -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_role"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Co-parent"
                        android:textSize="@dimen/text_label_small"
                        app:chipBackgroundColor="?attr/colorSecondaryContainer"
                        app:chipIcon="@drawable/ic_person"
                        app:chipIconSize="@dimen/spacing_4"
                        android:visibility="gone" />

                    <!-- Edit button (owner / co-parent) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_edit"
                        style="@style/Widget.Pf.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_detail_edit_button"
                        android:contentDescription="@string/child_detail_edit_button"
                        android:visibility="gone" />

                    <!-- Share button (owner only) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_share"
                        style="@style/Widget.Pf.Button.Secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/child_detail_share_button"
                        android:contentDescription="@string/child_detail_share_button"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Activity status: consolidated single card with accent stripe -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_activity_status"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_hero">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Single accent stripe for whole card -->
                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorPrimary"
                    android:alpha="0.7" />

                <!-- Rows container -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Feeding row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8"
                        android:paddingTop="@dimen/spacing_6"
                        android:paddingBottom="@dimen/spacing_6">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍼"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:text="Last Feeding"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/label_feeding"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="end"
                            tools:text="2h ago" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:background="?attr/colorSurfaceVariant"
                        android:alpha="0.3" />

                    <!-- Diaper row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8"
                        android:paddingTop="@dimen/spacing_6"
                        android:paddingBottom="@dimen/spacing_6">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💩"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:text="Last Diaper"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/label_diaper"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="end"
                            tools:text="30m ago" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:background="?attr/colorSurfaceVariant"
                        android:alpha="0.3" />

                    <!-- Nap row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8"
                        android:paddingTop="@dimen/spacing_6"
                        android:paddingBottom="@dimen/spacing_6">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😴"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:text="Last Nap"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/label_nap"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="end"
                            tools:text="1h ago" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Pattern alerts card (feeding and nap warnings) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_pattern_alerts"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_activity_status">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Amber accent stripe -->
                <View
                    android:layout_width="@dimen/accent_stripe_width"
                    android:layout_height="match_parent"
                    android:background="?attr/colorTertiary"
                    android:alpha="0.9" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_8"
                    android:paddingEnd="@dimen/spacing_8"
                    android:paddingTop="@dimen/spacing_6"
                    android:paddingBottom="@dimen/spacing_6">

                    <!-- Feeding alert row -->
                    <LinearLayout
                        android:id="@+id/row_feeding_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/text_feeding_alert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="Baby usually feeds every 3h — it's been 3h 30m" />
                    </LinearLayout>

                    <!-- Nap alert row (with margin if both are shown) -->
                    <LinearLayout
                        android:id="@+id/row_nap_alert"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="@dimen/spacing_4"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/text_nap_alert"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_4"
                            android:fontFamily="@font/dm_sans"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            tools:text="Baby usually naps after ~2h awake — awake for 2h 30m" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Today summary card (batch dashboard-summary); skeleton shown until loaded -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_today"
            style="@style/Widget.Pf.CardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:minHeight="72dp"
            app:layout_goneMarginTop="@dimen/spacing_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_pattern_alerts">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="72dp"
                android:padding="@dimen/spacing_8">

                <!-- Skeleton: visible while dashboardSummary is null -->
                <View
                    android:id="@+id/today_skeleton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:minHeight="56dp"
                    android:background="?attr/colorSurfaceVariant"
                    android:alpha="0.6"
                    android:contentDescription="@string/child_detail_today_loading"
                    android:importantForAccessibility="yes" />

                <!-- Real counts: visible when dashboardSummary is loaded -->
                <LinearLayout
                    android:id="@+id/today_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:minHeight="24dp"
                        android:background="?attr/colorTertiary"
                        android:alpha="0.7" />

                    <TextView
                        android:id="@+id/text_today_summary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_8"
                        android:fontFamily="@font/dm_sans"
                        android:textSize="@dimen/text_body_medium"
                        android:textColor="?attr/colorOnSurface"
                        tools:text="5 feedings, 3 diapers, 2 naps" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tracking shortcuts (action buttons with better spacing) -->
        <LinearLayout
            android:id="@+id/card_tracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_12"
            android:orientation="vertical"
            android:spacing="@dimen/spacing_4"
            android:clickable="false"
            android:focusable="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_today">

            <!-- Feedings navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_feedings"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:contentDescription="@string/a11y_go_to_feedings"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorPrimary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍼"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_feedings"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Diapers navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_diapers"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:contentDescription="@string/a11y_go_to_diapers"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorSecondary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💩"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_diapers"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Naps navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_naps"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:contentDescription="@string/a11y_go_to_naps"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorTertiary"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😴"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_naps"
                            android:fontFamily="@font/fredoka"
                            android:textSize="@dimen/text_body_medium"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Timeline navigation card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_timeline"
                style="@style/Widget.Pf.CardView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:contentDescription="@string/a11y_go_to_timeline"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:paddingEnd="@dimen/spacing_12">

                    <View
                        android:layout_width="@dimen/accent_stripe_width"
                        android:layout_height="match_parent"
                        android:background="?attr/colorSecondaryContainer"
                        android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/spacing_8"
                        android:paddingEnd="@dimen/spacing_8">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏱️"
                            android:textSize="18sp"
                            android:layout_marginEnd="@dimen/spacing_4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/child_detail_timeline"

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Pf.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:layout_marginStart="@dimen/spacing_0"
    android:layout_marginEnd="@dimen/spacing_0"
    android:layout_marginTop="@dimen/spacing_2"
    android:layout_marginBottom="@dimen/spacing_2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_8"
        android:paddingEnd="@dimen/spacing_8"
        android:paddingTop="@dimen/spacing_6"
        android:paddingBottom="@dimen/spacing_6">

        <!-- Event emoji -->
        <TextView
            android:id="@+id/event_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:layout_marginEnd="@dimen/spacing_8"
            tools:text="🍼" />

        <!-- Event summary and details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/event_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/fredoka"
                android:textSize="@dimen/text_body_medium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                tools:text="Bottle - 3.5 oz" />

        </LinearLayout>

        <!-- Time -->
        <TextView
            android:id="@+id/event_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_8"
            android:fontFamily="@font/dm_sans"
            android:textSize="@dimen/text_body_small"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="14:30" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

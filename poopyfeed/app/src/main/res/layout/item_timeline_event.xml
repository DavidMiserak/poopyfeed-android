<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Pf.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Color-coded accent stripe (set programmatically per event type) -->
        <View
            android:id="@+id/accent_stripe"
            android:layout_width="@dimen/accent_stripe_width"
            android:layout_height="match_parent"
            android:alpha="0.7"
            android:background="?attr/colorPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/spacing_8"
            android:paddingEnd="@dimen/spacing_8"
            android:paddingTop="@dimen/spacing_6"
            android:paddingBottom="@dimen/spacing_6"
            tools:ignore="NestedWeights">

            <!-- Event emoji -->
            <TextView
                android:id="@+id/event_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_8"
                android:textSize="22sp"
                tools:text="🍼" />

            <!-- Event summary and details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/event_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fredoka"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_body_medium"
                    tools:text="Bottle - 3.5 oz" />

            </LinearLayout>

            <!-- Time (local timezone) -->
            <TextView
                android:id="@+id/event_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_8"
                android:fontFamily="@font/dm_sans"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_body_small"
                tools:text="2:30 PM" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
